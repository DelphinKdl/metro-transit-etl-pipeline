# =============================================================================
# WMATA ETL Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Docker / Airflow Configuration
# -----------------------------------------------------------------------------
# Your user ID (run: id -u)
AIRFLOW_UID=

# -----------------------------------------------------------------------------
# WMATA API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get your API key at: https://developer.wmata.com/
WMATA_API_KEY=

# API timeout in seconds (default: 30)
WMATA_TIMEOUT=30

# Maximum retry attempts (default: 3)
WMATA_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Database credentials - CHANGE THESE IN PRODUCTION!
POSTGRES_USER=
POSTGRES_PASSWORD=

# Database host (use 'postgres' for Docker, 'localhost' for local)
POSTGRES_HOST=

# Database port
POSTGRES_PORT=5432

# Database name for ETL data
POSTGRES_DB=wmata_etl

# Database name for Airflow metadata
AIRFLOW_DB=wmata_airflow

# Full connection URL (constructed from above values)
# Format: postgresql://{user}:{password}@{host}:{port}/{db}
DATABASE_URL=

# -----------------------------------------------------------------------------
# Pipeline Configuration
# -----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Airflow Configuration (Docker only)
# -----------------------------------------------------------------------------
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
